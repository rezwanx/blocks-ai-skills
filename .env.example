# Frontend stack selection — "react", "blazor", or "blazor-tailwind"
FRONTEND_STACK=react

# Required — get these from Cloud Portal
API_BASE_URL=https://api.seliseblocks.com
X_BLOCKS_KEY=your_blocks_key_here
PROJECT_SLUG=your_project_slug_here
USERNAME=your_cloudadmin_email
PASSWORD=your_cloudadmin_password

# Conditional — only needed for specific flows
BLOCKS_OIDC_CLIENT_ID=
BLOCKS_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
CAPTCHA_SITE_KEY=
CAPTCHA_TYPE=

# Build configuration
GENERATE_SOURCEMAP=false

# Theme Colors - Can be in hex or hsl format (e.g., #1B9A8B or hsl(174, 69%, 41%))
PRIMARY_COLOR=#15969B
SECONDARY_COLOR=#5194B8

# Populated at runtime after authentication (do not fill manually)
ACCESS_TOKEN=
REFRESH_TOKEN=
